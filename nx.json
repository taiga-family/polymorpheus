{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "origin/main",
    "defaultProject": "demo",
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "production": ["default"],
        "sharedGlobals": [
            "{workspaceRoot}/nx.json",
            "{workspaceRoot}/tsconfig.*.json",
            "{workspaceRoot}/tsconfig.json"
        ]
    },
    "targetDefaults": {
        "build": {
            "cache": true,
            "inputs": ["default"]
        },
        "lint": {
            "cache": true
        },
        "test": {
            "cache": true,
            "inputs": ["default"]
        }
    },
    "tui": {
        "enabled": false
    },
    "workspaceLayout": {
        "appsDir": "projects",
        "libsDir": "projects"
    }
}
